d:{"id":"9eb2101c-8449-4a40-aa8f-4b5d0229fd6a","meeting_id":"meeting_10_infra_2026","topic_id":"3443bc38-207f-442a-9c95-29bb32bd5725","summary":"The team decided to move to a multi-cloud architecture, specifically AWS plus GCP, using Kubernetes as the deployment abstraction, with the target of GCP Frankfurt being live by end of Q1 2026.","verbatim_quote":"Marc: I agree. The single-cloud bet was the right call when we were twelve people chasing any deal. Now we have specific enterprise demand that requires optionality. Decision: we move to a multi-cloud architecture, AWS plus GCP, with Kubernetes as the deployment abstraction. Karim owns the migration plan, target is GCP Frankfurt live by end of Q1 2026.","confidence":"explicit","participants":"$e","decided_at":"2025-11-04","created_at":"2026-05-09T11:31:47.586670Z"}
2:["$","div",null,{"className":"px-10 py-10 anim-fadeup","children":[["$","div",null,{"className":"font-mono text-[10.5px] uppercase","style":{"color":"#96897B","letterSpacing":"0.16em"},"children":"Conflict registry"}],["$","h1",null,{"className":"font-serif mt-1","style":{"fontSize":40,"color":"#004E64","letterSpacing":"-0.005em","lineHeight":1.05},"children":"Contradictions"}],["$","p",null,{"className":"mt-2 text-[13.5px] max-w-[560px]","style":{"color":"rgba(0,78,100,0.70)"},"children":"Decisions that conflict with earlier rulings on the same topic. Burgundy markers indicate decisions that reverse a prior commitment."}],["$","div",null,{"className":"mt-8","children":[null,["$","$Lc",null,{"initialContradictions":[{"id":"cf9f6ab8-0570-4db4-9e7f-c7a6de322318","topic_id":"3443bc38-207f-442a-9c95-29bb32bd5725","decision_a_id":"b311a62a-5371-4ca9-9e97-4d3d19e74285","decision_b_id":"9eb2101c-8449-4a40-aa8f-4b5d0229fd6a","explanation":"Prior decision [1] explicitly decided to use ECS with Fargate for deployment and rejected Kubernetes. The new decision to use Kubernetes as the deployment abstraction directly contradicts this prior decision.","severity":"high","detected_at":"2026-05-09T11:31:51.986894Z","dismissed":false,"topic_slug":"cloud_strategy","topic_display_name":"Cloud Strategy","decision_a":{"id":"b311a62a-5371-4ca9-9e97-4d3d19e74285","meeting_id":"meeting_05_cloud_strategy","topic_id":"3443bc38-207f-442a-9c95-29bb32bd5725","summary":"Decided to use ECS with Fargate for deployment, explicitly rejecting Kubernetes.","verbatim_quote":"Marc: And David, this means the deployment tooling discussion is closed. ECS with Fargate, not Kubernetes.\nDavid: Confirmed. I'll kill the EKS spike.","confidence":"explicit","participants":["Marc","David"],"decided_at":"2025-09-30","created_at":"2026-05-09T11:28:35.928049Z"},"decision_b":{"id":"9eb2101c-8449-4a40-aa8f-4b5d0229fd6a","meeting_id":"meeting_10_infra_2026","topic_id":"3443bc38-207f-442a-9c95-29bb32bd5725","summary":"The team decided to move to a multi-cloud architecture, specifically AWS plus GCP, using Kubernetes as the deployment abstraction, with the target of GCP Frankfurt being live by end of Q1 2026.","verbatim_quote":"Marc: I agree. The single-cloud bet was the right call when we were twelve people chasing any deal. Now we have specific enterprise demand that requires optionality. Decision: we move to a multi-cloud architecture, AWS plus GCP, with Kubernetes as the deployment abstraction. Karim owns the migration plan, target is GCP Frankfurt live by end of Q1 2026.","confidence":"explicit","participants":["Marc","David","Karim","Inès"],"decided_at":"2025-11-04","created_at":"2026-05-09T11:31:47.586670Z"}},{"id":"fefe296b-7d7d-4143-b8c0-2c7e5fc85f43","topic_id":"3443bc38-207f-442a-9c95-29bb32bd5725","decision_a_id":"a7639843-482e-4e79-9aa2-608373649624","decision_b_id":"9eb2101c-8449-4a40-aa8f-4b5d0229fd6a","explanation":"Prior decision [0] explicitly adopted a single-cloud AWS strategy and rejected multi-cloud and GCP. The new decision to move to a multi-cloud architecture with AWS plus GCP directly contradicts this prior commitment.","severity":"high","detected_at":"2026-05-09T11:31:51.986888Z","dismissed":false,"topic_slug":"cloud_strategy","topic_display_name":"Cloud Strategy","decision_a":{"id":"a7639843-482e-4e79-9aa2-608373649624","meeting_id":"meeting_05_cloud_strategy","topic_id":"3443bc38-207f-442a-9c95-29bb32bd5725","summary":"Adopted a single-cloud strategy on AWS, rejecting multi-cloud and GCP, and committing to AWS-native services (RDS, ECS, S3, CloudFront).","verbatim_quote":"Sara: Okay. Decision: we are single-cloud on AWS. No multi-cloud, no GCP workloads, no Kubernetes-as-abstraction. We commit fully to AWS-native services where they make sense — RDS, ECS, S3, CloudFront. Karim owns the account structure.","confidence":"explicit","participants":["Marc","David","Karim","Sara"],"decided_at":"2025-09-30","created_at":"2026-05-09T11:28:35.314010Z"},"decision_b":"$d"}],"showDismissed":false}]]}]]}]
